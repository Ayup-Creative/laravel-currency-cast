{
    "name": "ayup-creative/laravel-currency-cast",
    "description": "Casts currency values to and from integers",
    "require": {
        "php": ">=8.2",
        "illuminate/database": "^12",
        "ext-intl": "*"
    },
    "require-dev": {
      "laravel/framework": "^12|^13.0",
      "laravel/pint": "^1.0",
      "orchestra/testbench": "^v10.0|v11.0",
      "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "AyupCreative\\Casts\\Currency\\": "src/"
        },
        "files": ["src/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "AyupCreative\\Casts\\Currency\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AyupCreative\\Casts\\Currency\\LaravelCurrencyCastServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint"
    }
}
